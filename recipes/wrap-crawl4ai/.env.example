# Copy to ".env" and fill in. NEVER commit a real .env (it is gitignored).
# These are read from the environment by the server — they are NOT tool inputs.

# --- Crawl4AI server ---
# Base URL of your running Crawl4AI instance (docker default shown).
CRAWL4AI_BASE_URL=http://127.0.0.1:11235
# Bearer token, only if your Crawl4AI server was started with JWT auth enabled.
CRAWL4AI_API_TOKEN=

# --- Transport (shared with the starter) ---
# MCP_TRANSPORT=stdio | http   (default stdio)
# MCP_HTTP_PORT=3000
# MCP_AUTH_TOKEN=               # bearer token required for the HTTP transport
