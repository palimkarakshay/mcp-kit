# Copy to ".env" and fill in. NEVER commit a real .env (it is gitignored).
# These are read from the environment by the servers — they are NOT tool inputs.

# --- GitHub server (optional) ---
# Public read works with no token (60 requests/hour/IP). A token raises the
# limit to 5,000/hour. A fine-grained token with public read scope is enough.
GITHUB_TOKEN=

# --- Anaplan server (required to run against a real tenant) ---
# Basic-auth credentials exchanged for a short-lived AnaplanAuthToken.
ANAPLAN_EMAIL=you@example.com
ANAPLAN_PASSWORD=your-anaplan-password
# Discover these ids with list_anaplan_actions once authenticated.
ANAPLAN_WORKSPACE_ID=your-workspace-id
ANAPLAN_MODEL_ID=your-model-id

# --- Transport (shared with the starter) ---
# MCP_TRANSPORT=stdio | http   (default stdio)
# MCP_HTTP_PORT=3000
# MCP_AUTH_TOKEN=               # bearer token required for the HTTP transport
